# ===========================================
# LLM Stock Analyst 环境变量配置示例
# ===========================================
# 复制此文件为 .env 并填入实际值

# -------------------------------------------
# 必需配置
# -------------------------------------------

# DashScope API Key (通义千问大模型)
# 获取方式：https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Tushare API Token (A 股数据接口)
# 获取方式：https://tushare.pro/user/token
TUSHARE_TOKEN=your_tushare_token_here

# -------------------------------------------
# 可选配置
# -------------------------------------------

# PostgreSQL 数据库 URI (用于持久化存储对话历史)
# 格式：postgresql://user:password@host:port/database
# 如果不配置，将使用内存存储（重启后数据丢失）
# DB_URI=postgresql://user:password@localhost:5432/stock_analyst

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# 日志文件路径 (可选，不配置则只输出到控制台)
# LOG_FILE=logs/stock_analyst.log

# -------------------------------------------
# 模型配置（可选）
# -------------------------------------------

# 默认模型：qwen3.5-flash
# 可选模型：qwen-turbo, qwen-plus, qwen-max
# MODEL_NAME=qwen3.5-flash

# 模型温度 (0.0-1.0, 越高越随机)
# MODEL_TEMPERATURE=0.7

# -------------------------------------------
# 注意事项
# -------------------------------------------
# 1. 不要将 .env 文件提交到 Git
# 2. 确保 API Key 和 Token 的安全
# 3. 生产环境建议使用环境变量注入而非文件
